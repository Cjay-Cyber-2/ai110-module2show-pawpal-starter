classDiagram
    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet: Pet) void
        +get_pet(name: str) Pet
        +get_all_tasks() List~Tuple~
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task: Task) void
        +get_tasks() List~Task~
    }

    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() Task
    }

    class Scheduler {
        -Owner owner
        +get_all_tasks() List~Tuple~
        +sort_by_time(tasks) List~Tuple~
        +filter_by_status(tasks, completed) List~Tuple~
        +filter_by_pet(tasks, pet_name) List~Tuple~
        +get_todays_schedule() List~Tuple~
        +detect_conflicts(tasks) List~str~
        +complete_task(pet_name, task_index) void
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : manages
